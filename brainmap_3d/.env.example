# Database
DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/brainmap_3d
# For local testing, you can use SQLite:
# DATABASE_URL=sqlite+aiosqlite:///./brainmap_3d.db

# LLM Configuration (DashScope / 阿里云百炼)
DASHSCOPE_API_KEY=your-dashscope-api-key
DASHSCOPE_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
LLM_MODEL=qwen-plus
LLM_MAX_TOKENS=4096
LLM_TEMPERATURE=0.7

# Application
APP_NAME=BrainMap 3D
APP_VERSION=1.0.0
DEBUG=true
HOST=0.0.0.0
PORT=8000
